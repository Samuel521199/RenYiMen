POSTGRES_DB=ai_workbench
POSTGRES_USER=ai_workbench
POSTGRES_PASSWORD=ai_workbench
POSTGRES_PORT=5432

# WorkFlow docker-compose 使用 workbench-db / workbench-redis 服务名
DATABASE_URL=postgresql+asyncpg://ai_workbench:ai_workbench@workbench-db:5432/ai_workbench
REDIS_URL=redis://workbench-redis:6379/0
REDIS_PORT=6379

SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
WORKBENCH_SSO_SECRET=change-me-workbench-sso-secret
# 阶段2灰度开关：
# allow_all -> 全部账号可用旧密码登录
# allow_admin_only -> 仅管理员可用旧密码登录（建议灰度阶段）
# disabled -> 完全关闭旧密码登录，仅走平台 SSO
WORKBENCH_LEGACY_PASSWORD_LOGIN_MODE=allow_admin_only
# 角色同步策略：
# platform_authoritative -> 平台角色单向覆盖 workbench 角色
# preserve_workbench_admin -> 保留现有 admin，不被平台 USER 自动降级
# no_auto_downgrade -> 仅从平台升级 admin，不自动降级
WORKBENCH_PLATFORM_ROLE_POLICY=platform_authoritative
# 兼容旧布尔开关（未配置 MODE 时生效）：true=allow_all, false=disabled
WORKBENCH_ALLOW_LEGACY_PASSWORD_LOGIN=true
# 阶段1兼容开关：true=SSO 可按历史 username 关联旧账号（避免重复建号）
WORKBENCH_SSO_LINK_BY_LEGACY_USERNAME=true

STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/storage
# /static/* 响应 Cache-Control max-age（秒，默认 86400 = 24h）
STATIC_CACHE_MAX_AGE=86400

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

BACKEND_PORT=8000
FRONTEND_PORT=3010
NEXT_PUBLIC_API_BASE=http://localhost:8000

# 模型 Key 主要在数据库 model_configs 表；也可在此填写（部分旧逻辑可能读取）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# GOOGLE_API_KEY=
# 302.ai（Kling 视频 / Gemini 视频分析）
# WORKBENCH_302AI_API_KEY=
