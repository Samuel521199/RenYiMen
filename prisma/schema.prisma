generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

/// 绉垎娴佹按绫诲瀷锛氬厖鍊?/ 娑堣€?
enum PointsTransactionType {
  RECHARGE
  CONSUME
}

/// 缃戝叧鐢熸垚浠诲姟鍦ㄥ簱涓殑鐢熷懡鍛ㄦ湡锛堜笌涓婃父 taskId 瀵归綈锛?
enum GenerationHistoryStatus {
  PENDING
  SUCCESS
  FAILED
}

enum VideoProjectStatus {
  DRAFT
  PLANNING
  PLAN_REVIEW
  IMAGE_GENERATING
  IMAGE_REVIEW
  MICRO_SHOT_REVIEW
  CLIP_GENERATING
  CLIP_REVIEW
  COMPOSING
  FINAL_REVIEW
  DONE
  FAILED
}

enum VideoShotStatus {
  SCRIPT_READY
  IMAGE_PENDING
  IMAGE_RUNNING
  IMAGE_READY
  IMAGE_APPROVED
  CLIP_PENDING
  CLIP_RUNNING
  CLIP_READY
  CLIP_APPROVED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  /// Credentials 鐧诲綍鐢紙OAuth 鐢ㄦ埛鍙负绌猴級
  passwordHash  String?   @map("password_hash")
  role          Role      @default(USER)
  /// 褰撳墠绉垎浣欓锛堟暣鏁帮級
  balance       Int       @default(0)

  accounts            Account[]
  sessions            Session[]
  transactions        Transaction[]
  apiLogs             ApiLog[]
  generationHistories GenerationHistory[]
  videoProjects       VideoProject[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model VideoProject {
  id                 String             @id @default(cuid())
  userId             String             @map("user_id")
  status             VideoProjectStatus @default(DRAFT)
  title              String             @default("")
  userPrompt         String             @map("user_prompt") @db.Text
  referenceImageUrls Json               @default("[]") @map("reference_image_urls")
  planJson           Json?              @map("plan_json")
  aspectRatio        String             @default("9:16") @map("aspect_ratio")
  durationSeconds    Int                @default(30) @map("duration_seconds")
  stylePreset        String             @default("") @map("style_preset")
  finalVideoUrl      String?            @map("final_video_url") @db.Text
  composeTaskId      String?            @map("compose_task_id")
  errorMessage       String?            @map("error_message") @db.Text

  user                      User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  shots                     VideoShot[]
  keyframes                 VideoKeyframe[]
  segments                  VideoSegment[]
  generationCandidates      VideoGenerationCandidate[]
  consistencyAnchorImages   VideoConsistencyAnchorImage[]
  anchorReferenceViews      VideoAnchorReferenceView[]
  referenceSelectionOutputs VideoReferenceSelectionOutput[]
  promptCompilations        VideoPromptCompilation[]
  generationQualityReports  VideoGenerationQualityReport[]
  audioAssets               VideoAudioAsset[]
  transitionReferences      VideoTransitionReference[]
  artifactMetadataRows      VideoArtifactMetadata[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@map("video_projects")
}

model VideoConsistencyAnchorImage {
  id           String       @id @default(cuid())
  projectId    String       @map("project_id")
  artifactId   String       @map("artifact_id")
  anchorId     String       @map("anchor_id")
  revision     Int          @default(1)
  imageUrl     String?      @map("image_url") @db.Text
  status       String       @default("draft")
  approved     Boolean      @default(false)
  userAccepted Boolean      @default(false) @map("user_accepted")
  payload      Json
  project      VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@unique([projectId, artifactId, revision])
  @@index([projectId, anchorId, approved])
  @@map("video_consistency_anchor_images")
}

model VideoAnchorReferenceView {
  id               String       @id @default(cuid())
  projectId        String       @map("project_id")
  artifactId       String       @map("artifact_id")
  anchorId         String       @map("anchor_id")
  view             String
  orientation      String       @default("unknown")
  revision         Int          @default(1)
  sourceArtifactId String?      @map("source_artifact_id")
  sourceRevisionId String?      @map("source_revision_id")
  imageUrl         String?      @map("image_url") @db.Text
  status           String       @default("draft")
  approved         Boolean      @default(false)
  payload          Json
  project          VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([projectId, artifactId, revision])
  @@index([projectId, anchorId, view, approved])
  @@map("video_anchor_reference_views")
}

model VideoReferenceSelectionOutput {
  id                    String       @id @default(cuid())
  projectId             String       @map("project_id")
  targetArtifactId      String       @map("target_artifact_id")
  targetType            String       @default("") @map("target_type")
  revision              Int          @default(1)
  selectedArtifactIds   Json         @default("[]") @map("selected_artifact_ids")
  selectedReferenceUrls Json         @default("[]") @map("selected_reference_urls")
  payload               Json
  project               VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  @@unique([projectId, targetArtifactId, revision])
  @@index([projectId, targetType, updatedAt])
  @@map("video_reference_selection_outputs")
}

model VideoPromptCompilation {
  id               String       @id @default(cuid())
  projectId        String       @map("project_id")
  targetArtifactId String       @map("target_artifact_id")
  targetType       String       @default("") @map("target_type")
  revision         Int          @default(1)
  finalPrompt      String       @default("") @map("final_prompt") @db.Text
  negativePrompt   String       @default("") @map("negative_prompt") @db.Text
  payload          Json
  project          VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([projectId, targetArtifactId, revision])
  @@index([projectId, targetType, updatedAt])
  @@map("video_prompt_compilations")
}

model VideoGenerationQualityReport {
  id               String       @id @default(cuid())
  projectId        String       @map("project_id")
  assetId          String       @map("asset_id")
  reportKey        String       @default("active") @map("report_key")
  candidateId      String?      @map("candidate_id")
  revision         Int          @default(1)
  passed           Boolean      @default(false)
  userAccepted     Boolean      @default(false) @map("user_accepted")
  compositeScore   Float?       @map("composite_score")
  retryInstruction String?      @map("retry_instruction") @db.Text
  payload          Json
  project          VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([projectId, assetId, reportKey, revision])
  @@index([projectId, passed, updatedAt])
  @@index([candidateId])
  @@map("video_generation_quality_reports")
}

model VideoAudioAsset {
  id         String       @id @default(cuid())
  projectId  String       @map("project_id")
  artifactId String       @map("artifact_id")
  kind       String
  revision   Int          @default(1)
  url        String?      @db.Text
  status     String       @default("draft")
  approved   Boolean      @default(false)
  active     Boolean      @default(false)
  payload    Json
  project    VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@unique([projectId, artifactId, revision])
  @@index([projectId, kind, active])
  @@map("video_audio_assets")
}

model VideoTransitionReference {
  id               String       @id @default(cuid())
  projectId        String       @map("project_id")
  artifactId       String       @map("artifact_id")
  revision         Int          @default(1)
  fromCameraId     String?      @map("from_camera_id")
  toCameraId       String       @default("") @map("to_camera_id")
  toSegmentNo      Int?         @map("to_segment_no")
  mode             String       @default("short")
  status           String       @default("planned")
  videoUrl         String?      @map("video_url") @db.Text
  selectedFrameUrl String?      @map("selected_frame_url") @db.Text
  locked           Boolean      @default(false)
  payload          Json
  project          VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([projectId, artifactId, revision])
  @@index([projectId, toCameraId, status])
  @@map("video_transition_references")
}

model VideoArtifactMetadata {
  id                       String       @id @default(cuid())
  projectId                String       @map("project_id")
  artifactId               String       @map("artifact_id")
  artifactType             String       @default("") @map("artifact_type")
  producedByStage          String       @default("") @map("produced_by_stage")
  revision                 Int          @default(1)
  status                   String       @default("draft")
  retryFromStage           String?      @map("retry_from_stage")
  userAccepted             Boolean      @default(false) @map("user_accepted")
  invalidatedByArtifactIds Json         @default("[]") @map("invalidated_by_artifact_ids")
  parentRevisionIds        Json         @default("[]") @map("parent_revision_ids")
  payload                  Json
  project                  VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  @@unique([projectId, artifactId, revision])
  @@index([projectId, status, retryFromStage])
  @@map("video_artifact_metadata")
}

model VideoGenerationCandidate {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")
  artifactId       String   @map("artifact_id")
  targetId         String   @map("target_id")
  kind             String
  batchId          String   @map("batch_id")
  candidateNo      Int      @map("candidate_no")
  taskId           String?  @map("task_id")
  mediaUrl         String?  @map("media_url") @db.Text
  status           String   @default("pending")
  prompt           String   @default("") @db.Text
  negativePrompt   String   @default("") @map("negative_prompt") @db.Text
  qualityReport    Json?    @map("quality_report")
  compositeScore   Float?   @map("composite_score")
  passed           Boolean?
  selected         Boolean  @default(false)
  userAccepted     Boolean  @default(false) @map("user_accepted")
  retryInstruction String?  @map("retry_instruction") @db.Text
  errorMessage     String?  @map("error_message") @db.Text
  metadata         Json?

  project VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, artifactId, batchId, candidateNo])
  @@index([projectId, artifactId, createdAt])
  @@index([projectId, status])
  @@map("video_generation_candidates")
}

model VideoShot {
  id              String          @id @default(cuid())
  projectId       String          @map("project_id")
  shotNo          Int             @map("shot_no")
  status          VideoShotStatus @default(SCRIPT_READY)
  durationSeconds Int             @default(5) @map("duration_seconds")
  purpose         String          @default("") @db.Text
  camera          String          @default("") @db.Text
  action          String          @default("") @db.Text
  imagePrompt     String          @map("image_prompt") @db.Text
  videoPrompt     String          @map("video_prompt") @db.Text
  negativePrompt  String          @default("") @map("negative_prompt") @db.Text
  subtitle        String          @default("") @db.Text
  imageUrl        String?         @map("image_url") @db.Text
  clipUrl         String?         @map("clip_url") @db.Text
  imageTaskId     String?         @map("image_task_id")
  clipTaskId      String?         @map("clip_task_id")
  qualityScore    Int?            @map("quality_score")
  errorMessage    String?         @map("error_message") @db.Text
  locked          Boolean         @default(false)

  project VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, shotNo])
  @@index([projectId, status])
  @@map("video_shots")
}

model VideoKeyframe {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  keyframeNo     Int             @map("keyframe_no")
  timeSeconds    Int             @map("time_seconds")
  status         VideoShotStatus @default(SCRIPT_READY)
  purpose        String          @default("") @db.Text
  scene          String          @default("") @db.Text
  characterState String          @default("") @map("character_state") @db.Text
  productState   String          @default("") @map("product_state") @db.Text
  imagePrompt    String          @map("image_prompt") @db.Text
  negativePrompt String          @default("") @map("negative_prompt") @db.Text
  imageUrl       String?         @map("image_url") @db.Text
  imageTaskId    String?         @map("image_task_id")
  qualityScore   Int?            @map("quality_score")
  errorMessage   String?         @map("error_message") @db.Text
  locked         Boolean         @default(false)

  project VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, keyframeNo])
  @@index([projectId, status])
  @@map("video_keyframes")
}

model VideoSegment {
  id                String          @id @default(cuid())
  projectId         String          @map("project_id")
  segmentNo         Int             @map("segment_no")
  status            VideoShotStatus @default(SCRIPT_READY)
  startKeyframeNo   Int             @map("start_keyframe_no")
  endKeyframeNo     Int             @map("end_keyframe_no")
  startTimeSeconds  Int             @map("start_time_seconds")
  endTimeSeconds    Int             @map("end_time_seconds")
  durationSeconds   Int             @default(5) @map("duration_seconds")
  purpose           String          @default("") @db.Text
  motion            String          @default("") @db.Text
  camera            String          @default("") @db.Text
  subjectMotion     String          @default("") @map("subject_motion") @db.Text
  environmentMotion String          @default("") @map("environment_motion") @db.Text
  videoPrompt       String          @map("video_prompt") @db.Text
  negativePrompt    String          @default("") @map("negative_prompt") @db.Text
  subtitle          String          @default("") @db.Text
  clipUrl           String?         @map("clip_url") @db.Text
  clipTaskId        String?         @map("clip_task_id")
  qualityScore      Int?            @map("quality_score")
  errorMessage      String?         @map("error_message") @db.Text
  locked            Boolean         @default(false)

  project VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, segmentNo])
  @@index([projectId, status])
  @@map("video_segments")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// 绉垎娴佹按锛氭瘡涓€绗斿厖鍊兼垨娑堣€楋紙amount 涓哄甫绗﹀彿鏁存暟锛屾秷鑰椾竴鑸负璐燂級
model Transaction {
  id          String                @id @default(cuid())
  userId      String                @map("user_id")
  type        PointsTransactionType
  amount      Int
  taskId      String?               @map("task_id")
  description String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("transactions")
}

/// API 璋冪敤鏃ュ織锛堟垚鏈环 / 鍞环 / 姣涘埄锛?
model ApiLog {
  id             String   @id @default(cuid())
  userId         String?  @map("user_id")
  endpoint       String
  requestPayload Json?    @map("request_payload")
  responseStatus Int?     @map("response_status")
  /// 涓婃父浠诲姟 ID锛堝 RunningHub taskId锛?
  externalTaskId String?  @map("external_task_id")
  /// 缃戝叧澶勭悊鑰楁椂锛堟绉掞級
  durationMs     Int?     @map("duration_ms")
  costPrice      Decimal? @map("cost_price") @db.Decimal(18, 6)
  sellPrice      Decimal? @map("sell_price") @db.Decimal(18, 6)
  profit         Decimal? @db.Decimal(18, 6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([endpoint, createdAt])
  @@map("api_logs")
}

/// 缃戝叧鎻愬崟涓庣粓鎬佽惤搴擄紙鎸変笂娓?taskId 鍞竴锛涗笌 User 澶栭敭鍏宠仈锛?
model GenerationHistory {
  id               String                  @id @default(cuid())
  userId           String                  @map("user_id")
  taskId           String                  @unique @map("task_id")
  skuId            String                  @map("sku_id")
  providerCode     String                  @default("") @map("provider_code")
  status           GenerationHistoryStatus @default(PENDING)
  mediaType        String                  @default("") @map("media_type")
  resultUrl        String?                 @map("result_url") @db.Text
  /// 鎴愬姛缁堟€佸墠涓烘彁鍗曞弬鑰冩垚鏈紱鎴愬姛鍚庝笌瀹炴墸绉垎涓€鑷达紙涓庝綑棰濇墸鍑忓榻愶級
  cost             Int                     @default(0)
  /// 涓婃父 RunningHub 瀹為檯娑堣€?RH 甯侊紙鑻ョ姸鎬?杈撳嚭鎺ュ彛鍙В鏋愶級
  actualCost       Int?                    @map("actual_cost")
  /// 鎻愬崟鏃剁櫥璁扮殑搴曞浘/绱犳潗澶у皬锛堝瓧鑺傦級锛屼緵缁堟€佷笌涓婃父瑙ｆ瀽鍊煎悎骞惰璐?
  sourceAssetBytes Int?                    @map("source_asset_bytes")
  /// 涓婃父浠诲姟瀹為檯鎵ц鑰楁椂锛堢锛夛紝濡?RunningHub `usage.taskCostTime`
  durationInt      Int                     @default(0) @map("duration_int")
  /// 缁堟€佷负 FAILED 鏃剁殑閿欒鍘熷洜锛堟潵鑷笂娓告垨缃戝叧锛夛紱PENDING/SUCCESS 涓虹┖
  errorMessage     String?                 @map("error_message") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@map("generation_histories")
}
