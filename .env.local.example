# 复制本文件为 `.env.local` 并填写真实值（勿将 `.env.local` 提交到 Git）

# —— PostgreSQL（Prisma）——
# 标准连接串，示例为本地 Docker Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/workflow?schema=public"

# —— NextAuth.js v5 / Auth.js ——
# 随机长密钥：可执行 `openssl rand -base64 32` 生成
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# 应用绝对地址（生产环境必填；本地统一使用 http://localhost:3001）
AUTH_URL="http://localhost:3001"

# GitHub OAuth（可选；未配置时仅启用 Credentials 登录）
# 在 GitHub Developer Settings 创建 OAuth App，Callback 填：
#   http://localhost:3001/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# 新用户注册时钱包初始积分（0 = 仅开通空钱包；本地调试可设 100）
REGISTER_WELCOME_CREDITS="0"

# —— 前端（既有）——
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# —— RunningHub（网关转发）——
# 生产环境务必只通过环境变量注入，勿将 Key 提交仓库
RUNNINGHUB_API_KEY=
RUNNINGHUB_API_BASE_URL=https://www.runninghub.cn

# —— 阿里云百炼 / DashScope（一句话成片真实生成链路）——
# BAILIAN_API_KEY=
# 或 DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
# DASHSCOPE_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_STORYBOARD_MODEL=qwen3.7-plus
ALIYUN_STORYBOARD_VISION_MODEL=qwen-vl-max
# Stream three-stage JSON planner calls via DashScope OpenAI-compatible SSE.
ONE_PROMPT_VIDEO_JSON_STAGE_STREAM=true
ONE_PROMPT_VIDEO_JSON_STAGE_TIMEOUT_MS=180000
ONE_PROMPT_VIDEO_JSON_STAGE_STREAM_IDLE_TIMEOUT_MS=90000
ONE_PROMPT_VIDEO_JSON_STAGE_STREAM_MAX_TIMEOUT_MS=600000
ONE_PROMPT_VIDEO_SEGMENT_STAGE_STREAM_MAX_TIMEOUT_MS=240000
# Split shot_decomposer into per-segment JSON calls. Set to whole to use the legacy single request.
ONE_PROMPT_VIDEO_SHOT_DECOMPOSER_MODE=segment
ONE_PROMPT_VIDEO_SHOT_DECOMPOSER_CONCURRENCY=3
ONE_PROMPT_VIDEO_SHOT_DECOMPOSER_RETRY_ATTEMPTS=3
ONE_PROMPT_VIDEO_SHOT_DECOMPOSER_RETRY_BASE_DELAY_MS=2000
ONE_PROMPT_VIDEO_SINGLE_TAKE_MAX_REVISIONS=2
ALIYUN_IMAGE_MODEL=wan2.7-image-pro
ALIYUN_I2V_MODEL=vidu/viduq3-turbo_start-end2video
ALIYUN_I2V_RESOLUTION=720P
# Vidu Q3 can generate native music and sound effects. Set false for silent clips.
ALIYUN_I2V_AUDIO=true
# One-prompt planner architecture: v2 (default), v2_shadow, or v1.
ONE_PROMPT_VIDEO_PLANNER_ARCH=v2
# Story rollout: off = old behavior, warn = report only, strict = block bad story after rewrite attempts.
ONE_PROMPT_VIDEO_STORY_GATE=off
ONE_PROMPT_VIDEO_STORY_REWRITE_MAX=0
ONE_PROMPT_VIDEO_STORY_CONTRACT_REPAIR_MAX=2
ALIYUN_STORYBOARD_REFERENCE_FACT_MODEL=qwen-vl-plus
ONE_PROMPT_VIDEO_SHOT_GROUPING=on

# Phase-9 rollout: disable independently for immediate legacy fallback.
ONE_PROMPT_REFERENCE_SELECTOR_V2=true
ONE_PROMPT_THREE_VIEW_DERIVATION=true
ONE_PROMPT_STRICT_VALIDATION=true
ONE_PROMPT_VISUAL_QUALITY_EVAL=true
ONE_PROMPT_TRANSITION_REFERENCE=true
ONE_PROMPT_UNIFIED_AUDIO_MIX=true
ONE_PROMPT_ARTIFACT_GRAPH_V2=true
ONE_PROMPT_ROLLOUT_COHORT=internal

# Phase-10 artifact tables: keep reads off until dual-write reconciliation passes.
ONE_PROMPT_ARTIFACT_TABLES_DUAL_WRITE=false
ONE_PROMPT_ARTIFACT_TABLES_READ=false
# One-prompt video generation concurrency. Bailian currently allows up to 5 running tasks per model.
ONE_PROMPT_VIDEO_IMAGE_CONCURRENCY=3
ONE_PROMPT_VIDEO_CLIP_CONCURRENCY=2

# One-prompt final composition uses local ffmpeg + OSS upload.
# Set transition seconds to 0 for hard cuts; default is 0.35.
# FFMPEG_PATH="D:/soft/ffmpeg-8.0.1-essentials_build/bin/ffmpeg.exe"
# ONE_PROMPT_COMPOSE_TRANSITION_SECONDS=0.35

# —— 阿里云智能媒体服务 IMS / ICE（多镜头最终合成）——
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_IMS_REGION=cn-shanghai
# ALIYUN_IMS_ENDPOINT=https://ice.cn-shanghai.aliyuncs.com/
# ALIYUN_IMS_OUTPUT_TARGET=oss-object
# ALIYUN_IMS_OUTPUT_MEDIA_URL_TEMPLATE=https://your-bucket.oss-cn-shanghai.aliyuncs.com/one-prompt-video/{projectId}-{timestamp}.mp4
# 或输出到 VOD：
# ALIYUN_IMS_OUTPUT_TARGET=vod-media
# ALIYUN_IMS_VOD_STORAGE_LOCATION=outin-xxxx.oss-cn-shanghai.aliyuncs.com
# ALIYUN_IMS_VOD_TEMPLATE_GROUP_ID=VOD_NO_TRANSCODE

# 图生视频：v2 `POST /openapi/v2/run/workflow/{id}` 中的数字 workflowId（示例：1987043435041460226）
RUNNINGHUB_IMG2VIDEO_REMOTE_WORKFLOW_ID=""
# 可选：图生视频 Comfy JSON 路径（不设且仓库含 config/runninghub/lu-img2video-workflow.json 时会自动随请求发送完整 workflow）
# RUNNINGHUB_IMG2VIDEO_WORKFLOW_FILE="config/runninghub/lu-img2video-workflow.json"
# 首尾帧生成视频：`POST /openapi/v2/run/workflow/{id}`（示例：1987043353088954370，对应控制台 `/run/workflow/...`）
RUNNINGHUB_SVD_REMOTE_WORKFLOW_ID=""

# 文生图：同上（示例：1987052252043087873）
RUNNINGHUB_TXT2IMG_REMOTE_WORKFLOW_ID=""

# 可选；不设则自动使用仓库 config/runninghub/lu-shortdrama-txt2img-workflow.json
RUNNINGHUB_TXT2IMG_WORKFLOW_FILE="config/runninghub/lu-shortdrama-txt2img-workflow.json"

# 可选：整段 JSON 字符串（与 WORKFLOW_FILE 二选一）
# RUNNINGHUB_TXT2IMG_WORKFLOW_JSON=""

# —— S3 兼容 OSS（浏览器 PUT 预签名，见 POST /api/upload/presign）——
# OSS_REGION="oss-cn-hangzhou"
# OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"
# OSS_ACCESS_KEY_ID=""
# OSS_SECRET_ACCESS_KEY=""
# OSS_BUCKET_NAME=""
# OSS_PUBLIC_DOMAIN="https://your-cdn.example.com"
# OSS_FORCE_PATH_STYLE="false"
