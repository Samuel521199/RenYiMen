# 复制本文件为 `.env.local` 并填写真实值（勿将 `.env.local` 提交到 Git）

# —— PostgreSQL（Prisma）——
# 标准连接串，示例为本地 Docker Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/workflow?schema=public"

# —— NextAuth.js v5 / Auth.js ——
# 随机长密钥：可执行 `openssl rand -base64 32` 生成
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# 应用绝对地址（生产环境必填；本地可省略或设为 http://localhost:3000）
AUTH_URL="http://localhost:3000"

# GitHub OAuth（可选；未配置时仅启用 Credentials 登录）
# 在 GitHub Developer Settings 创建 OAuth App，Callback 填：
#   http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# 新用户注册时钱包初始积分（0 = 仅开通空钱包；本地调试可设 100）
REGISTER_WELCOME_CREDITS="0"

# —— 前端（既有）——
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# —— RunningHub（网关转发）——
# 生产环境务必只通过环境变量注入，勿将 Key 提交仓库
RUNNINGHUB_API_KEY=dafe6f7aa9b04b239d74cf184d4f5c56
RUNNINGHUB_API_BASE_URL=https://www.runninghub.cn

# 图生视频：v2 `POST /openapi/v2/run/workflow/{id}` 中的数字 workflowId（示例：1987043435041460226）
RUNNINGHUB_IMG2VIDEO_REMOTE_WORKFLOW_ID=""
# 可选：图生视频 Comfy JSON 路径（不设且仓库含 config/runninghub/lu-img2video-workflow.json 时会自动随请求发送完整 workflow）
# RUNNINGHUB_IMG2VIDEO_WORKFLOW_FILE="config/runninghub/lu-img2video-workflow.json"
# 首尾帧生成视频：`POST /openapi/v2/run/workflow/{id}`（示例：1987043353088954370，对应控制台 `/run/workflow/...`）
RUNNINGHUB_SVD_REMOTE_WORKFLOW_ID=""

# 文生图：同上（示例：1987052252043087873）
RUNNINGHUB_TXT2IMG_REMOTE_WORKFLOW_ID=""

# 可选；不设则自动使用仓库 config/runninghub/lu-shortdrama-txt2img-workflow.json
RUNNINGHUB_TXT2IMG_WORKFLOW_FILE="config/runninghub/lu-shortdrama-txt2img-workflow.json"

# 可选：整段 JSON 字符串（与 WORKFLOW_FILE 二选一）
# RUNNINGHUB_TXT2IMG_WORKFLOW_JSON=""

# —— S3 兼容 OSS（浏览器 PUT 预签名，见 POST /api/upload/presign）——
# OSS_REGION="oss-cn-hangzhou"
# OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"
# OSS_ACCESS_KEY_ID=""
# OSS_SECRET_ACCESS_KEY=""
# OSS_BUCKET_NAME=""
# OSS_PUBLIC_DOMAIN="https://your-cdn.example.com"
# OSS_FORCE_PATH_STYLE="false"
