# 公共环境变量模板（可提交仓库）。本地开发请优先使用 `.env.local`（见 `.env.local.example`）

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# —— 数据库密码（生产必须修改，不要用默认值）——
# 用 openssl rand -base64 24 生成强密码
POSTGRES_PASSWORD=postgres
WORKBENCH_POSTGRES_PASSWORD=ai_workbench
# Redis 密码（可选，留空则不启用认证；生产建议设置）
REDIS_PASSWORD=

# —— URL 编码版密码（密码含 / + = 等特殊字符时必须填写）——
# 规则：/ → %2F，+ → %2B，= → %3D，其余字母数字无需编码
# 若密码不含特殊字符，填与上面相同即可；不填则自动回退到原始密码（仅适用于纯字母数字密码）
# POSTGRES_PASSWORD_ENCODED=
# WORKBENCH_POSTGRES_PASSWORD_ENCODED=

# Prisma（亦可在 prisma.config.ts 通过 dotenv 加载）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workflow?schema=public

# NextAuth.js v5（须与浏览器实际访问地址一致：含端口；经 Nginx 80 则不要写 :3001）
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3001
# 示例（仅 Nginx 80 已启动且安全组放行 80）：
# AUTH_URL=http://你的服务器IP
# 示例（直连 web 3001，未启 Nginx）：
# AUTH_URL=http://你的服务器IP:3001
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# 管理端独立登录（与 NextAuth 管理员角色二选一即可进后台）。未设置用户名/密码时默认为 admin / admin，生产务必修改。
ADMIN_PANEL_USERNAME=
ADMIN_PANEL_PASSWORD=
# 生产默认仅 HTTPS 下发管理端 Cookie；HTTP 部署请设为 false
ADMIN_PANEL_COOKIE_SECURE=
# 签名管理端 Cookie；未设置时回退 AUTH_SECRET（再否则开发占位串，切勿用于生产）
ADMIN_PANEL_SESSION_SECRET=

# 新用户注册时写入钱包的欢迎积分（0 表示仅开通空钱包）
REGISTER_WELCOME_CREDITS=0

# 文生图：RunningHub 控制台中的数字 workflowId（必填，否则上游返回 404 NOT_FOUND）
# 与前端 Schema 的 workflowId 不同；你提供的 LU_短剧六件套之一_文生图_api.json 为图结构，不含此 ID，须在 RunningHub 网页复制
RUNNINGHUB_TXT2IMG_REMOTE_WORKFLOW_ID=

# 可选：文生图 Comfy JSON 文件路径（相对项目根）；不设且存在 config/runninghub/lu-shortdrama-txt2img-workflow.json 时会自动使用该文件（已由仓库收录 LU 导出）
# RUNNINGHUB_TXT2IMG_WORKFLOW_FILE=config/runninghub/lu-shortdrama-txt2img-workflow.json

# 可选：文生图完整 Comfy JSON 字符串（API 字段 workflow）；与 WORKFLOW_FILE 二选一即可
# RUNNINGHUB_TXT2IMG_WORKFLOW_JSON=

# RunningHub（可选；生产请在真实环境变量中配置，勿提交密钥）
RUNNINGHUB_API_KEY=
RUNNINGHUB_API_BASE_URL=https://www.runninghub.cn

# 阿里云百炼 / DashScope（图生视频等；网关 `providerCode: ALIYUN_BAILIAN`）。**请在本地 `.env.local` 中配置**（勿提交密钥仓库）：
# BAILIAN_API_KEY=
# 或 DASHSCOPE_API_KEY=
# 可选：国际区或新加坡地域时修改
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
# OpenAI 兼容接口 base；不填时默认使用 `${DASHSCOPE_BASE_URL}/compatible-mode/v1`
# DASHSCOPE_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 一句话成片真实链路模型
ALIYUN_STORYBOARD_MODEL=qwen3.7-plus
ALIYUN_STORYBOARD_VISION_MODEL=qwen-vl-max
# Reference Selector v2 uses the vision model only to score conflicts and view match;
# deterministic backend rules still make the final selection.
ALIYUN_REFERENCE_VISION_MODEL=qwen-vl-max
ONE_PROMPT_REFERENCE_VISION_EVAL=true
ONE_PROMPT_REFERENCE_VISION_TIMEOUT_MS=30000
ALIYUN_END_FRAME_VISION_MODEL=qwen-vl-max
ONE_PROMPT_END_FRAME_VISION_EVAL=true
ONE_PROMPT_END_FRAME_VISION_TIMEOUT_MS=45000
ONE_PROMPT_END_FRAME_MAX_RETRIES=2
ALIYUN_GENERATION_QUALITY_VISION_MODEL=qwen3.6-flash
ONE_PROMPT_GENERATION_QUALITY_VISION_EVAL=true
ONE_PROMPT_GENERATION_QUALITY_TIMEOUT_MS=90000
ONE_PROMPT_GENERATION_QUALITY_CONCURRENCY=2
ONE_PROMPT_GENERATION_QUALITY_REQUEST_ATTEMPTS=2
ONE_PROMPT_GENERATION_QUALITY_RETRY_DELAY_MS=1500
ONE_PROMPT_GENERATION_QUALITY_EVALUATIONS_PER_SYNC=2
ONE_PROMPT_GENERATION_QUALITY_RETRY_CYCLES=2
ONE_PROMPT_GENERATION_QUALITY_CYCLE_RETRY_DELAY_MS=5000
# Candidate-card copy editor. Runs only when issue details are first expanded,
# so it never blocks media generation or visual quality evaluation.
ALIYUN_QUALITY_SUMMARY_MODEL=qwen-flash
ONE_PROMPT_QUALITY_SUMMARY_TIMEOUT_MS=8000
ONE_PROMPT_IMAGE_CANDIDATE_COUNT=1
ONE_PROMPT_VIDEO_CANDIDATE_COUNT=2
ONE_PROMPT_GENERATION_MAX_RETRIES=2

# One Prompt Video phase-9 independent rollout flags. Set any flag to false to use its legacy fallback.
ONE_PROMPT_REFERENCE_SELECTOR_V2=true
ONE_PROMPT_THREE_VIEW_DERIVATION=true
ONE_PROMPT_STRICT_VALIDATION=true
ONE_PROMPT_VISUAL_QUALITY_EVAL=true
ONE_PROMPT_TRANSITION_REFERENCE=true
ONE_PROMPT_UNIFIED_AUDIO_MIX=true
ONE_PROMPT_ARTIFACT_GRAPH_V2=true
ONE_PROMPT_ROLLOUT_COHORT=internal

# Optional phase-10 table split. Apply the migration first, then enable dual write, verify, and finally switch reads.
ONE_PROMPT_ARTIFACT_TABLES_DUAL_WRITE=false
ONE_PROMPT_ARTIFACT_TABLES_READ=false
# short: approved parent keyframe is used directly as scene-layout evidence.
# full: generate a transition-reference video, extract/evaluate frames, and require review+lock.
ONE_PROMPT_TRANSITION_REFERENCE_MODE=short
# Stream three-stage JSON planner calls via DashScope OpenAI-compatible SSE.
ONE_PROMPT_VIDEO_JSON_STAGE_STREAM=true
ONE_PROMPT_VIDEO_JSON_STAGE_TIMEOUT_MS=180000
ONE_PROMPT_VIDEO_JSON_STAGE_STREAM_IDLE_TIMEOUT_MS=90000
ONE_PROMPT_VIDEO_JSON_STAGE_STREAM_MAX_TIMEOUT_MS=600000
ONE_PROMPT_VIDEO_SEGMENT_STAGE_STREAM_MAX_TIMEOUT_MS=240000
# Split shot_decomposer into per-segment JSON calls. Set to whole to use the legacy single request.
ONE_PROMPT_VIDEO_SHOT_DECOMPOSER_MODE=segment
ONE_PROMPT_VIDEO_SHOT_DECOMPOSER_CONCURRENCY=3
ONE_PROMPT_VIDEO_SHOT_DECOMPOSER_RETRY_ATTEMPTS=3
ONE_PROMPT_VIDEO_SHOT_DECOMPOSER_RETRY_BASE_DELAY_MS=2000
ONE_PROMPT_VIDEO_SINGLE_TAKE_MAX_REVISIONS=2
ALIYUN_IMAGE_MODEL=wan2.7-image-pro
ALIYUN_I2V_MODEL=vidu/viduq3-turbo_start-end2video
ALIYUN_I2V_RESOLUTION=720P
# Vidu Q3 can generate native music and sound effects. Set false for silent clips.
ALIYUN_I2V_AUDIO=true
# One-prompt planner architecture: v2 (default), v2_shadow, or v1.
ONE_PROMPT_VIDEO_PLANNER_ARCH=v2
# Story rollout: off = old behavior, warn = report only, strict = block bad story after rewrite attempts.
ONE_PROMPT_VIDEO_STORY_GATE=off
ONE_PROMPT_VIDEO_STORY_REWRITE_MAX=0
ONE_PROMPT_VIDEO_STORY_CONTRACT_REPAIR_MAX=2
ALIYUN_STORYBOARD_REFERENCE_FACT_MODEL=qwen-vl-plus
ONE_PROMPT_VIDEO_SHOT_GROUPING=on
# 默认 false，避免上游自动扩写把“一镜到底/禁止段内转场”的硬约束冲淡；需要扩写时显式设 true
ALIYUN_I2V_PROMPT_EXTEND=false
# One-prompt video generation concurrency. Bailian currently allows up to 5 running tasks per model.
ONE_PROMPT_VIDEO_IMAGE_CONCURRENCY=3
ONE_PROMPT_VIDEO_CLIP_CONCURRENCY=2

# One-prompt final composition uses local ffmpeg + OSS upload.
# Set transition seconds to 0 for hard cuts; default is 0.35.
# FFMPEG_PATH="D:/soft/ffmpeg-8.0.1-essentials_build/bin/ffmpeg.exe"
# ONE_PROMPT_COMPOSE_TRANSITION_SECONDS=0.35

# 阿里云智能媒体服务 IMS / ICE（多镜头合成）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_IMS_REGION=cn-shanghai
# ALIYUN_IMS_ENDPOINT=https://ice.cn-shanghai.aliyuncs.com/
# 输出到 OSS：必须是当前 IMS 区域可访问的 OSS 外网 Endpoint URL，支持 {projectId}/{timestamp} 占位
# ALIYUN_IMS_OUTPUT_TARGET=oss-object
# ALIYUN_IMS_OUTPUT_MEDIA_URL_TEMPLATE=https://your-bucket.oss-cn-shanghai.aliyuncs.com/one-prompt-video/{projectId}-{timestamp}.mp4
# 或输出到 VOD：
# ALIYUN_IMS_OUTPUT_TARGET=vod-media
# ALIYUN_IMS_VOD_STORAGE_LOCATION=outin-xxxx.oss-cn-shanghai.aliyuncs.com
# ALIYUN_IMS_VOD_TEMPLATE_GROUP_ID=VOD_NO_TRANSCODE

# OpenAPI v2：`POST /openapi/v2/run/workflow/{数字ID}`。
# 图生视频（大厅「图生视频」SKU，如 `/run/workflow/1987043435041460226` 中的数字 ID）
RUNNINGHUB_IMG2VIDEO_REMOTE_WORKFLOW_ID=
# 可选：图生视频完整 Comfy JSON 文件（相对项目根）；不设且存在 config/runninghub/lu-img2video-workflow.json 时随请求发送完整 workflow
# RUNNINGHUB_IMG2VIDEO_WORKFLOW_FILE=config/runninghub/lu-img2video-workflow.json
# 可选：图生视频完整 Comfy JSON 字符串（与 WORKFLOW_FILE 二选一）
# RUNNINGHUB_IMG2VIDEO_WORKFLOW_JSON=
# 首尾帧生成视频（大厅「首尾帧生成视频」SKU；控制台如 `/run/workflow/1987043353088954370` 中的数字 ID）；也可设通用 RUNNINGHUB_REMOTE_WORKFLOW_ID
RUNNINGHUB_SVD_REMOTE_WORKFLOW_ID=
# 可选：首尾帧完整 Comfy JSON（与图生视频同理）；不设且存在 config/runninghub/lu-flf2video-workflow.json 时随请求发送完整 workflow，避免仅 nodeInfoList 触发 Custom validation
# RUNNINGHUB_SVD_WORKFLOW_FILE=config/runninghub/lu-flf2video-workflow.json
# RUNNINGHUB_SVD_WORKFLOW_JSON=

# 分镜生成出图：POST /openapi/v2/run/workflow/1991312445449023489
RUNNINGHUB_STORYBOARD_REMOTE_WORKFLOW_ID=
# 可选：分镜 Comfy JSON 文件（相对项目根）；不设且存在 config/runninghub/lu-storyboard-workflow.json 时自动使用
# RUNNINGHUB_STORYBOARD_WORKFLOW_FILE=config/runninghub/lu-storyboard-workflow.json

# 提示词反推工作流（Qwen3 VQA 图生文）
RUNNINGHUB_PROMPT_REVERSE_WORKFLOW_ID=
# RUNNINGHUB_PROMPT_REVERSE_WORKFLOW_FILE=config/runninghub/lu-prompt-reverse-workflow.json

# 换头换脸工作流（Best-Face-Swap，双图输入：底图 + 换脸源图）
RUNNINGHUB_FACE_SWAP_WORKFLOW_ID=
# RUNNINGHUB_FACE_SWAP_WORKFLOW_FILE=config/runninghub/lu-face-swap-workflow.json

# 高清放大 AI App（单图输入，接口 /openapi/v2/run/ai-app/{id}，不需要 workflow JSON 文件）
RUNNINGHUB_HD_UPSCALE_APP_ID=

# 人像抠图 AI App（单图输入，输出透明背景 PNG）
RUNNINGHUB_MATTING_APP_ID=

# 背景替换 AI App（双图输入：用户图 + 背景图）
RUNNINGHUB_BG_REPLACE_APP_ID=

# 视频模糊一键修复 AI App（单视频输入 + 最大边选择）
RUNNINGHUB_VIDEO_ENHANCE_APP_ID=

# —— S3 兼容对象存储（POST /api/upload/presign 直传）——
# OSS_FORCE_PATH_STYLE=false

# —— AI 社媒工作台（FastAPI 后端，Next.js 经 /api/workbench 代理）——
# Workbench 后端地址（Docker 内为 http://workbench-backend:8000）
WORKBENCH_BACKEND_URL=http://localhost:8000
# 本地开发可选：静态图直连 backend，绕过 Next.js 代理（避免大图日志告警；img 标签可跨域）
# NEXT_PUBLIC_WORKBENCH_STATIC_BASE=http://localhost:8000
# Docker Compose：Nginx 对外 HTTP 端口（生产建议经 80 访问，静态图走 Nginx 磁盘缓存）
NGINX_HTTP_PORT=80
# 素材/成品静态图浏览器缓存秒数（默认 86400 = 24h）；Next.js 代理 /api/workbench/static/*
WORKBENCH_STATIC_CACHE_MAX_AGE=86400
# 磁盘容量统计路径（默认 ./ai-workflow-data/storage，即素材存储所在盘）
# DISK_USAGE_PATH=./ai-workflow-data/storage
# 告警阈值（百分比）
# DISK_USAGE_WARN_PERCENT=80
# DISK_USAGE_CRITICAL_PERCENT=90
# SSO 桥接密钥（须与 ai-workflow-code/.env 中 WORKBENCH_SSO_SECRET 一致）
WORKBENCH_SSO_SECRET=change-me-workbench-sso-secret

# Workbench 模型 API（也可在 /workbench/admin/models 配置；历史库导入后可能已有 model_configs）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# GOOGLE_API_KEY=
# 302.ai（Kling 视频草稿/精品、Gemini 视频动作分析）
# WORKBENCH_302AI_API_KEY=

# —— 定时清理 cron（/api/cron/cleanup）——
# 设置后外部 cron 服务须携带此密钥；不设置则仅允许本机调用
# CRON_SECRET=your-secret-here
