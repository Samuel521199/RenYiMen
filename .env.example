# 公共环境变量模板（可提交仓库）。本地开发请优先使用 `.env.local`（见 `.env.local.example`）

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Prisma（亦可在 prisma.config.ts 通过 dotenv 加载）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workflow?schema=public

# NextAuth.js v5
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# 管理端独立登录（与 NextAuth 管理员角色二选一即可进后台）。未设置用户名/密码时默认为 admin / admin，生产务必修改。
ADMIN_PANEL_USERNAME=
ADMIN_PANEL_PASSWORD=
# 生产默认仅 HTTPS 下发管理端 Cookie；HTTP 部署请设为 false
ADMIN_PANEL_COOKIE_SECURE=
# 签名管理端 Cookie；未设置时回退 AUTH_SECRET（再否则开发占位串，切勿用于生产）
ADMIN_PANEL_SESSION_SECRET=

# 新用户注册时写入钱包的欢迎积分（0 表示仅开通空钱包）
REGISTER_WELCOME_CREDITS=0

# 文生图：RunningHub 控制台中的数字 workflowId（必填，否则上游返回 404 NOT_FOUND）
# 与前端 Schema 的 workflowId 不同；你提供的 LU_短剧六件套之一_文生图_api.json 为图结构，不含此 ID，须在 RunningHub 网页复制
RUNNINGHUB_TXT2IMG_REMOTE_WORKFLOW_ID=

# 可选：文生图 Comfy JSON 文件路径（相对项目根）；不设且存在 config/runninghub/lu-shortdrama-txt2img-workflow.json 时会自动使用该文件（已由仓库收录 LU 导出）
# RUNNINGHUB_TXT2IMG_WORKFLOW_FILE=config/runninghub/lu-shortdrama-txt2img-workflow.json

# 可选：文生图完整 Comfy JSON 字符串（API 字段 workflow）；与 WORKFLOW_FILE 二选一即可
# RUNNINGHUB_TXT2IMG_WORKFLOW_JSON=

# RunningHub（可选；未设置时网关使用代码内开发默认 Key，生产请必填）
RUNNINGHUB_API_KEY=
RUNNINGHUB_API_BASE_URL=https://www.runninghub.cn

# 阿里云百炼 / DashScope（图生视频等；网关 `providerCode: ALIYUN_BAILIAN`）。**请在本地 `.env.local` 中配置**（勿提交密钥仓库）：
# BAILIAN_API_KEY=
# 或 DASHSCOPE_API_KEY=
# 可选：国际区或新加坡地域时修改
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com

# OpenAPI v2：`POST /openapi/v2/run/workflow/{数字ID}`。
# 图生视频（大厅「图生视频」SKU，如 `/run/workflow/1987043435041460226` 中的数字 ID）
RUNNINGHUB_IMG2VIDEO_REMOTE_WORKFLOW_ID=
# 可选：图生视频完整 Comfy JSON 文件（相对项目根）；不设且存在 config/runninghub/lu-img2video-workflow.json 时随请求发送完整 workflow
# RUNNINGHUB_IMG2VIDEO_WORKFLOW_FILE=config/runninghub/lu-img2video-workflow.json
# 可选：图生视频完整 Comfy JSON 字符串（与 WORKFLOW_FILE 二选一）
# RUNNINGHUB_IMG2VIDEO_WORKFLOW_JSON=
# 首尾帧生成视频（大厅「首尾帧生成视频」SKU；控制台如 `/run/workflow/1987043353088954370` 中的数字 ID）；也可设通用 RUNNINGHUB_REMOTE_WORKFLOW_ID
RUNNINGHUB_SVD_REMOTE_WORKFLOW_ID=
# 可选：首尾帧完整 Comfy JSON（与图生视频同理）；不设且存在 config/runninghub/lu-flf2video-workflow.json 时随请求发送完整 workflow，避免仅 nodeInfoList 触发 Custom validation
# RUNNINGHUB_SVD_WORKFLOW_FILE=config/runninghub/lu-flf2video-workflow.json
# RUNNINGHUB_SVD_WORKFLOW_JSON=

# 分镜生成出图：POST /openapi/v2/run/workflow/1991312445449023489
RUNNINGHUB_STORYBOARD_REMOTE_WORKFLOW_ID=
# 可选：分镜 Comfy JSON 文件（相对项目根）；不设且存在 config/runninghub/lu-storyboard-workflow.json 时自动使用
# RUNNINGHUB_STORYBOARD_WORKFLOW_FILE=config/runninghub/lu-storyboard-workflow.json

# 提示词反推工作流（Qwen3 VQA 图生文）
RUNNINGHUB_PROMPT_REVERSE_WORKFLOW_ID=
# RUNNINGHUB_PROMPT_REVERSE_WORKFLOW_FILE=config/runninghub/lu-prompt-reverse-workflow.json

# 可选：与官方 run/workflow 示例一致时可省略
# RUNNINGHUB_INSTANCE_TYPE=default
# 多用户并发时建议开启：任务进入个人队列串行执行，避免同 GPU 显存溢出（OOM）
RUNNINGHUB_USE_PERSONAL_QUEUE=true

# —— S3 兼容对象存储（POST /api/upload/presign 直传发牌）——
# OSS_REGION=oss-cn-hangzhou
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=
# OSS_SECRET_ACCESS_KEY=
# OSS_BUCKET_NAME=
# 公网访问根（无尾斜杠），如 CDN 或 Bucket 静态域名：https://cdn.example.com
# OSS_PUBLIC_DOMAIN=
# MinIO 等路径风格兼容时可设：OSS_FORCE_PATH_STYLE=true
# OSS_FORCE_PATH_STYLE=false
